        <mxCell id="kp95dOqZLEUA7gDUFuZ4-96" value="Некачественные данные о бронировании могут привести к путанице в учете доступной недвижимости и нарушению процесса продаж, что снизит эффективность бизнеса." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;align=left;container=0;" parent="kp95dOqZLEUA7gDUFuZ4-93" vertex="1">
          <mxGeometry y="30" width="250" height="116" as="geometry" />
