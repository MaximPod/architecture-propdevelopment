        <mxCell id="kp95dOqZLEUA7gDUFuZ4-92" value="Потеря данных о бронировании недвижимости сделает невозможным отслеживание текущих сделок и выполнение обязательств перед клиентами, что приведет к конфликтам и потере репутации." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;align=left;container=0;" parent="kp95dOqZLEUA7gDUFuZ4-89" vertex="1">
          <mxGeometry y="30" width="250" height="116" as="geometry" />
