        <mxCell id="kp95dOqZLEUA7gDUFuZ4-90" value="Риск: &lt;br&gt;&lt;b&gt;потеря данных&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e51400;strokeColor=#B20000;container=0;fontColor=#ffffff;" parent="kp95dOqZLEUA7gDUFuZ4-89" vertex="1">
